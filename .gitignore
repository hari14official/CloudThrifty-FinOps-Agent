# ==============================================================================
# SENSITIVE DATA & CREDENTIALS
# ==============================================================================
# DANGER: Never commit AWS credentials, webhook URLs, or API keys!
.env
.env.*
*.pem
credentials.json
aws_credentials/

# Terraform variables often contain secrets (e.g. SLACK_WEBHOOK_URL)
terraform.tfvars
terraform.tfvars.json
*.auto.tfvars
*.auto.tfvars.json

# ==============================================================================
# TERRAFORM
# ==============================================================================
# Local .terraform directories
**/.terraform/*
.terraform/

# .tfstate files (must be ignored to prevent state and secrets from leaking)
*.tfstate
*.tfstate.*
*.tfstate.backup
crash.log
crash.*.log

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# ==============================================================================
# PYTHON
# ==============================================================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
venv/
.venv/
env/
pip-log.txt
pip-delete-this-directory.txt

# Testing
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ==============================================================================
# TEMPORARY & LOCAL FILES
# ==============================================================================
# Local AWS Lambda invocation output
response.json
*.log

# ==============================================================================
# OS SPECIFIC FILES
# ==============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
ehthumbs_vista.db
[Tt]humbs.db
